---
import { getCategoryBadgeClass, getStatusBadgeClass } from '@lib/content-utils';
import type { ProjectMeta } from '@lib/content-utils';
import { type Locale, t, projectPath } from '@lib/i18n';

interface Props {
  project: ProjectMeta;
  locale?: Locale;
}

const { project, locale = 'en' as Locale } = Astro.props;
const href = projectPath(project.slug, locale);
---

<a
  href={href}
  class="block p-5 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] hover:border-[var(--color-accent)] hover:shadow-md transition-all group"
>
  <div class="flex items-center gap-2 mb-3">
    <span class={getCategoryBadgeClass(project.category)}>
      {t(`category_${project.category}`, locale)}
    </span>
    <span class={getStatusBadgeClass(project.status)}>
      {t(`status_${project.status}`, locale)}
    </span>
  </div>

  <h3 class="text-lg font-semibold group-hover:text-[var(--color-accent)] transition-colors mb-1">
    {project.title}
  </h3>

  {project.subtitle && (
    <p class="text-sm text-[var(--color-text-secondary)] mb-2">
      {project.subtitle}
    </p>
  )}

  <p class="text-sm text-[var(--color-text-muted)] line-clamp-2">
    {project.description}
  </p>
</a>
