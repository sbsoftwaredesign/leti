---
import '@styles/global.css';
import '@styles/document.css';
import ThemeToggle from '@components/ThemeToggle';
import BurgerMenu from '@components/BurgerMenu';
import SearchOverlay from '@components/SearchOverlay';
import LanguageSwitcher from '@components/LanguageSwitcher';
import type { ProjectMeta } from '@lib/content-utils';
import { type Locale, t, localeFromSlug, stripLocalePrefix } from '@lib/i18n';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description?: string;
  currentSlug?: string;
  locale?: Locale;
}

const { title, description, currentSlug, locale = 'en' as Locale } = Astro.props;
const localDesc = description ?? t('professional_documents', locale);

const allProjects = await getCollection('projects');
const localeProjects = allProjects.filter((p) => (p.data.locale ?? 'en') === locale);
const projectMetas: ProjectMeta[] = localeProjects
  .map((p) => ({
    title: p.data.title,
    subtitle: p.data.subtitle,
    date: p.data.date,
    category: p.data.category,
    status: p.data.status,
    order: p.data.order,
    description: p.data.description,
    slug: stripLocalePrefix(p.id),
  }))
  .sort((a, b) => a.order - b.order);

const displaySlug = currentSlug ? stripLocalePrefix(currentSlug) : undefined;
---

<!doctype html>
<html lang={locale === 'es' ? 'es-AR' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={localDesc} />
    <meta name="color-scheme" content="light dark" />
    <title>{title} · Leticia Cáceres</title>
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('writer-factory-theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="min-h-dvh">
    <a href="#main" class="skip-link">{t('skip_to_content', locale)}</a>

    <header class="sticky top-0 z-30 bg-[var(--color-bg)]/95 backdrop-blur-sm border-b border-[var(--color-border)]" style="height: var(--header-height);">
      <div class="max-w-5xl mx-auto flex items-center justify-between px-4 py-3 desktop-sidebar-offset">
        <div class="flex items-center gap-2">
          <BurgerMenu
            client:load
            projects={projectMetas}
            currentSlug={displaySlug}
            locale={locale}
          />
          <a href={locale === 'es' ? '/es/' : '/'} class="font-serif font-semibold text-lg hover:text-[var(--color-accent)] transition-colors">
            Leticia Cáceres
          </a>
        </div>

        <div class="flex items-center gap-1">
          <SearchOverlay client:idle />
          <LanguageSwitcher client:load locale={locale} currentSlug={displaySlug} />
          <ThemeToggle client:load />
        </div>
      </div>
    </header>

    <main id="main" class="max-w-5xl mx-auto px-4 py-8 pb-20 desktop-sidebar-offset">
      <slot />
    </main>

    <footer class="fixed-footer desktop-sidebar-offset">
      <div class="max-w-5xl mx-auto px-4 py-3 text-center text-xs text-[var(--color-text-muted)]">
        &copy; {new Date().getFullYear()} Leticia Cáceres · {t('footer_rights', locale)}
      </div>
    </footer>
  </body>
</html>
