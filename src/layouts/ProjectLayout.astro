---
import BaseLayout from './BaseLayout.astro';
import MarkdownViewer from '@components/MarkdownViewer';
import { getCategoryBadgeClass, getStatusBadgeClass } from '@lib/content-utils';
import type { Category, Status } from '@lib/content-utils';
import { type Locale, t, getLocaleDateFormat } from '@lib/i18n';

interface Props {
  title: string;
  subtitle?: string;
  category: Category;
  status: Status;
  date: string;
  slug: string;
  rawMarkdown: string;
  locale?: Locale;
}

const { title, subtitle, category, status, date, slug, rawMarkdown, locale = 'en' as Locale } = Astro.props;
const pdfPath = locale === 'es' ? `/exports/es/${slug}.pdf` : `/exports/${slug}.pdf`;
const mdPath = locale === 'es' ? `/exports/es/${slug}.md` : `/exports/${slug}.md`;
const dateLocale = getLocaleDateFormat(locale);
---

<BaseLayout title={title} currentSlug={slug} locale={locale}>
  <article>
    <div class="sticky-page-header">
      <div class="flex items-center justify-between flex-wrap gap-2">
        <div class="flex items-center gap-2">
          <span class={getCategoryBadgeClass(category)}>
            {t(`category_${category}`, locale)}
          </span>
          <span class={getStatusBadgeClass(status)}>
            {t(`status_${status}`, locale)}
          </span>
          <span class="text-xs text-[var(--color-text-muted)]">
            {new Date(date).toLocaleDateString(dateLocale, { year: 'numeric', month: 'long' })}
          </span>
        </div>

        <div class="flex items-center gap-2">
          <a
            href={pdfPath}
            download={`${slug}.pdf`}
            class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-lg border border-[var(--color-border)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors"
            aria-label={`${t('download_pdf', locale)} ${title}`}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            {t('download_pdf', locale)}
          </a>
          <a
            href={mdPath}
            download={`${slug}.md`}
            class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-lg border border-[var(--color-border)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors"
            aria-label={`${t('download_markdown', locale)} ${title}`}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
            {t('download_markdown', locale)}
          </a>
        </div>
      </div>

      {subtitle && (
        <p class="text-[var(--color-text-secondary)] text-lg mt-2">{subtitle}</p>
      )}
    </div>

    <div class="document-content">
      <slot />
    </div>

    <div class="mt-10">
      <MarkdownViewer client:visible markdown={rawMarkdown} />
    </div>
  </article>
</BaseLayout>
