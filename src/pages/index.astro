---
import BaseLayout from '@layouts/BaseLayout.astro';
import ProjectCard from '@components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { CATEGORY_LABELS, CATEGORY_ORDER, type ProjectMeta } from '@lib/content-utils';

const allProjects = await getCollection('projects');

const projectMetas: ProjectMeta[] = allProjects
  .map((p) => ({
    title: p.data.title,
    subtitle: p.data.subtitle,
    date: p.data.date,
    category: p.data.category,
    status: p.data.status,
    order: p.data.order,
    description: p.data.description,
    slug: p.id,
  }))
  .sort((a, b) => a.order - b.order);

// Group by category
const grouped = new Map<string, ProjectMeta[]>();
for (const cat of CATEGORY_ORDER) {
  const items = projectMetas.filter((p) => p.category === cat);
  if (items.length > 0) grouped.set(cat, items);
}
---

<BaseLayout title="Documents">
  <div class="mb-8">
    <h1 class="text-3xl font-serif font-bold mb-2">Documents</h1>
    <p class="text-[var(--color-text-secondary)]">
      Professional documents and application materials for Leticia Cáceres.
    </p>
  </div>

  {Array.from(grouped.entries()).map(([category, items]) => (
    <section class="mb-10">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-4">
        {CATEGORY_LABELS[category as keyof typeof CATEGORY_LABELS]}
      </h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {items.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    </section>
  ))}
</BaseLayout>
